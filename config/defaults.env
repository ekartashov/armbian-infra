# config/defaults.env — shared defaults for all boards
# Board-specific overrides go in config/boards/<board>.env

# ── Pull stage ───────────────────────────────────────────────────────────────

ARMBIAN_DISTRO="trixie"
ARMBIAN_BRANCH="current"
ARMBIAN_VARIANT="minimal"
# ARMBIAN_VERSION=""
ARMBIAN_CATALOG_MAX_AGE=3600

# ── Patch stage ──────────────────────────────────────────────────────────────

PATCH_USER="admin"
PATCH_ROOT_MODE="locked"              # "locked" | "password"
PATCH_XZ_LEVEL=6                      # recompression (6 = armbian default)
PATCH_OVERLAY="tmpfs"                 # "false" | "tmpfs"  (qemu-user-static required if set)

# Extra packages to bake into the image (space-separated).
# Requires qemu-user-static on the host (same as PATCH_OVERLAY).
# These are installed via chroot apt-get before overlay (if any).
PATCH_EXTRA_PKGS="btrfs-progs rsync parted gdisk dosfstools btrbk"
