# /etc/btrbk/btrbk.conf — generated by armbian-base provisioning
# {{ target_hostname }}

transaction_log   /var/log/btrbk.log
lockfile          /var/lock/btrbk.lock
timestamp_format  long-iso

volume {{ btrbk_toplevel_mount }}
  snapshot_dir @snapshots

  subvolume @
    snapshot_name root
    snapshot_preserve_min  {{ btrbk_root_preserve_min }}
    snapshot_preserve      {{ btrbk_root_preserve }}

  subvolume @home
    snapshot_name home
    snapshot_preserve_min  {{ btrbk_home_preserve_min }}
    snapshot_preserve      {{ btrbk_home_preserve }}

  subvolume @srv
    snapshot_name srv
    snapshot_preserve_min  {{ btrbk_srv_preserve_min }}
    snapshot_preserve      {{ btrbk_srv_preserve }}
